# Database
# 아래 값은 로컬/docker 데모용 약값이다. 실 결제(prod) 배포 시엔 강력한 고유값으로 교체 —
# prod 프로파일은 DbSecretGuard 가 약한값(rootpw·changeme 등)·change-this 마커를 거부해 기동을 막는다(#321).
DB_HOST=localhost
DB_PORT=3306
DB_NAME=groove
DB_USERNAME=groove
DB_PASSWORD=changeme
MYSQL_ROOT_PASSWORD=changeme-root

# JWT
# ⚠️ 운영 배포 전 반드시 교체 — 아래 플레이스홀더 그대로면 기동 거부됨(#165). 256bit(32바이트) 이상 고유값 사용.
JWT_SECRET=change-this-to-a-256-bit-secret-key-in-production
JWT_ACCESS_TOKEN_TTL_SECONDS=1800
JWT_REFRESH_TOKEN_TTL_SECONDS=1209600

# Email Hash (#186) — 이메일 점유 해시 HMAC 키. JWT 와 분리된 전용 키(키 1개=용도 1개).
# ⚠️ 운영 배포 전 반드시 교체 — 아래 플레이스홀더 그대로면 기동 거부됨(#165). 256bit(32바이트) 이상 고유값 사용.
EMAIL_HASH_SECRET=change-this-to-a-256-bit-email-hash-key-in-production

# Metrics Scrape (#343) — /actuator/prometheus Basic 인증. docker 데모는 observability 프로파일에서 prometheus 를
# 노출하므로 필요하다. 이 password 는 monitoring/prometheus/prometheus.yml 의 basic_auth.password 와 일치해야
# 스크레이프가 동작한다(Prometheus 설정은 env 확장 미지원이라 양쪽을 같은 값으로 맞춘다).
# ⚠️ prod 에서 prometheus 를 노출하면 MetricsScrapeSecretGuard 가 약한/플레이스홀더(change-me 등) 값을 거부한다.
METRICS_SCRAPE_USERNAME=metrics
METRICS_SCRAPE_PASSWORD=change-me-demo

# Rate Limiting (Bucket4j)
RATE_LIMIT_LOGIN_CAPACITY=10
RATE_LIMIT_SIGNUP_CAPACITY=3

# Payment Mock — Mock 프로파일(local/dev/docker)에서만 사용. 값은 ISO-8601 Duration(예: 100ms, 1s).
PAYMENT_MOCK_SUCCESS_RATE=0.95
PAYMENT_MOCK_DELAY_MIN=100ms
PAYMENT_MOCK_DELAY_MAX=500ms
PAYMENT_MOCK_WEBHOOK_DELAY_MIN=1s
PAYMENT_MOCK_WEBHOOK_DELAY_MAX=5s
# ⚠️ 운영 배포 전 반드시 교체 — 아래 플레이스홀더 그대로면 기동 거부됨(#165).
PAYMENT_MOCK_WEBHOOK_SECRET=change-this-mock-webhook-secret-in-production

# Payment Toss (#293) — dev/prod 프로파일에서만 사용(test/local 은 Mock). 토스 개발자센터 테스트 키.
# client-key 는 브라우저 위젯용 공개 키(가드 없음), secret-key 는 서버 API 인증(Basic Auth)용 비밀 키. 둘 다 test_ 접두.
PAYMENT_TOSS_BASE_URL=https://api.tosspayments.com
PAYMENT_TOSS_CLIENT_KEY=test_ck_xxxxxxxxxxxxxxxxx
# ⚠️ 운영 배포 전 반드시 교체 — 아래 플레이스홀더(change-this 마커) 그대로면 기동 거부됨(#165). 실제 test_sk_ 키로 교체.
PAYMENT_TOSS_SECRET_KEY=test_sk_change-this-in-production
PAYMENT_TOSS_SUCCESS_URL=http://localhost:8080/payments/toss/success
PAYMENT_TOSS_FAIL_URL=http://localhost:8080/payments/toss/fail
PAYMENT_TOSS_CONNECT_TIMEOUT=2s
PAYMENT_TOSS_READ_TIMEOUT=5s

# Spring Profile (local | docker | test | dev | prod). docker-compose 는 app 서비스 environment 에서 docker 로 덮어쓴다.
# 로컬에서 ./gradlew bootRun 직접 실행 시에는 build.gradle.kts 가 local 을 자동 주입하므로 이 값에 의존하지 않는다.
# 실 결제(토스 실 PG)는 dev(테스트 연동 확인)/prod(실 배포) — Mock 은 제외되고 위 PAYMENT_TOSS_* 실 키가 필요하다(런북: docs/ARCHITECTURE.md §10.6).
SPRING_PROFILES_ACTIVE=docker

# API Docs (#162) — docker(배포) 프로파일은 기본 비공개(404)로 전 API 표면의 익명 노출을 차단한다.
# Swagger UI/OpenAPI 를 데모로 노출하려면 true 로 둔다. (local/test 프로파일은 이 값과 무관하게 항상 노출)
SPRINGDOC_ENABLED=false

# Reverse Proxy / Refresh 쿠키 (#265) — app 앞단의 nginx 가 TLS 를 종단한다.
# 아래 false 는 로컬 compose(nginx :80 http) 데모 전용이다(Secure 쿠키는 http 로 전송되지 않으므로).
# ⚠️ 운영(HTTPS) 배포 시 반드시 true 로 변경 — false 인 채 443 으로 띄우면 refresh 쿠키가 Secure 없이
#    발급돼 평문 채널로도 노출된다. 운영은 nginx 443 이 X-Forwarded-Proto: https 를 전달하므로
#    app(forward-headers-strategy: native)이 이를 인식해 Secure 쿠키/HSTS 를 발급한다.
AUTH_REFRESH_COOKIE_SECURE=false
