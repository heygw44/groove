meta {
  name: List Artist's Albums
  type: http
  seq: 8
  tags: [
    catalog
  ]
}

get {
  url: {{baseUrl}}/artists/{{artistId}}/albums
  body: none
  auth: inherit
}

params:query {
  page: 0
  size: 20
}

script:post-response {
  test('Status 200', () => expect(res.getStatus()).to.equal(200));
  test('content 배열', () => expect(res.getBody().content).to.be.an('array'));
}
