meta {
  name: List Albums
  type: http
  seq: 1
  tags: [
    catalog
  ]
}

get {
  url: {{baseUrl}}/albums
  body: none
  auth: inherit
}

params:query {
  page: 0
  size: 20
  sort: createdAt,desc
  ~keyword: 
  ~genreId: 
  ~artistId: 
  ~minPrice: 
  ~maxPrice: 
  ~isLimited: true
}

script:post-response {
  test('Status 200', () => expect(res.getStatus()).to.equal(200));
  test('content 배열', () => expect(res.getBody().content).to.be.an('array'));
}
