meta {
  name: Get Artist Detail
  type: http
  seq: 7
  tags: [
    catalog
  ]
}

get {
  url: {{baseUrl}}/artists/{{artistId}}
  body: none
  auth: inherit
}

script:post-response {
  test('Status 200', () => expect(res.getStatus()).to.equal(200));
  test('has name', () => expect(res.getBody()).to.have.property('name'));
}
