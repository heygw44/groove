meta {
  name: List Coupon Policies
  type: http
  seq: 2
  tags: [
    admin
  ]
}

get {
  url: {{baseUrl}}/admin/coupons
  body: none
  auth: inherit
}

params:query {
  page: 0
  size: 20
  ~status: ACTIVE
}

headers {
  Authorization: Bearer {{adminAccessToken}}
}

script:post-response {
  test('Status 200', () => expect(res.getStatus()).to.equal(200));
  test('content 배열', () => expect(res.getBody().content).to.be.an('array'));
}
