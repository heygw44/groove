meta {
  name: Update Genre
  type: http
  seq: 2
  tags: [
    admin
  ]
}

put {
  url: {{baseUrl}}/admin/genres/{{createdGenreId}}
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{adminAccessToken}}
  Content-Type: application/json
}

body:json {
  {
    "name": "GenreUpd-{{$randomUUID}}"
  }
}

script:post-response {
  test('Status 200', () => expect(res.getStatus()).to.equal(200));
}
