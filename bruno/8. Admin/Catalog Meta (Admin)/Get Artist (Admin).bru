meta {
  name: Get Artist (Admin)
  type: http
  seq: 7
  tags: [
    admin
  ]
}

get {
  url: {{baseUrl}}/admin/artists/{{createdArtistId}}
  body: none
  auth: inherit
}

headers {
  Authorization: Bearer {{adminAccessToken}}
}

script:post-response {
  test('Status 200', () => expect(res.getStatus()).to.equal(200));
}
