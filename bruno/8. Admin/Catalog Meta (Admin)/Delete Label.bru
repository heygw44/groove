meta {
  name: Delete Label
  type: http
  seq: 5
  tags: [
    admin
  ]
}

delete {
  url: {{baseUrl}}/admin/labels/{{createdLabelId}}
  body: none
  auth: inherit
}

headers {
  Authorization: Bearer {{adminAccessToken}}
}

script:post-response {
  test('Status 204 또는 409(사용 중)', () => expect([204, 409]).to.include(res.getStatus()));
}
