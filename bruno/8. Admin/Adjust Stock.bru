meta {
  name: Adjust Stock
  type: http
  seq: 5
  tags: [
    admin
  ]
}

patch {
  url: {{baseUrl}}/admin/albums/{{createdAlbumId}}/stock
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{adminAccessToken}}
  Content-Type: application/json
}

body:json {
  {
    "delta": 10
  }
}

script:post-response {
  test('Status 200', () => expect(res.getStatus()).to.equal(200));
}
