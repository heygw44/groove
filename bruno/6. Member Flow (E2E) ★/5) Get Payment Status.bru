meta {
  name: 5) Get Payment Status
  type: http
  seq: 5
  tags: [
    memberflow
  ]
}

get {
  url: {{baseUrl}}/payments/{{paymentId}}
  body: none
  auth: inherit
}

headers {
  Authorization: Bearer {{accessToken}}
}

script:post-response {
  test('Status 200', () => expect(res.getStatus()).to.equal(200));
  test('has status', () => expect(res.getBody()).to.have.property('status'));
}
