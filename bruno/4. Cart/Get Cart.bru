meta {
  name: Get Cart
  type: http
  seq: 2
  tags: [
    cart
  ]
}

get {
  url: {{baseUrl}}/cart
  body: none
  auth: inherit
}

headers {
  Authorization: Bearer {{accessToken}}
}

script:post-response {
  test('Status 200', () => expect(res.getStatus()).to.equal(200));
  test('has totalAmount', () => expect(res.getBody()).to.have.property('totalAmount'));
}
