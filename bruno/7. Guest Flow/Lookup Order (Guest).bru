meta {
  name: Lookup Order (Guest)
  type: http
  seq: 2
  tags: [
    guestflow
  ]
}

post {
  url: {{baseUrl}}/orders/{{guestOrderNumber}}/guest-lookup
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "guest@example.com"
  }
}

script:post-response {
  test('Status 200', () => expect(res.getStatus()).to.equal(200));
}
