meta {
  name: Health Check
  type: http
  seq: 1
  tags: [
    health
  ]
}

get {
  url: http://localhost:8080/actuator/health
  body: none
  auth: inherit
}

script:post-response {
  test('Status 200', () => expect(res.getStatus()).to.equal(200));
  test('status UP', () => expect(res.getBody().status).to.eql('UP'));
}
