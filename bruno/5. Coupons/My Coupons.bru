meta {
  name: My Coupons
  type: http
  seq: 3
  tags: [
    coupons
  ]
}

get {
  url: {{baseUrl}}/members/me/coupons
  body: none
  auth: inherit
}

params:query {
  page: 0
  size: 20
  sort: issuedAt,desc
  ~status: ISSUED
}

headers {
  Authorization: Bearer {{accessToken}}
}

script:post-response {
  test('Status 200', () => expect(res.getStatus()).to.equal(200));
  test('content 배열', () => expect(res.getBody().content).to.be.an('array'));
}
