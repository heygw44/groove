meta {
  name: 배송 완료 전 리뷰 → 422
  type: http
  seq: 4
  tags: [
    edge
  ]
}

post {
  url: {{baseUrl}}/reviews
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{accessToken}}
  Content-Type: application/json
}

body:json {
  {
    "orderNumber": "{{orderNumber}}",
    "albumId": 1,
    "rating": 5,
    "content": "아직 배송 안 왔는데 리뷰 시도"
  }
}

script:post-response {
  test('Status 422', () => expect(res.getStatus()).to.equal(422));
}
