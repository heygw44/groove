meta {
  name: Get My Profile
  type: http
  seq: 1
  tags: [
    members
  ]
}

get {
  url: {{baseUrl}}/members/me
  body: none
  auth: inherit
}

headers {
  Authorization: Bearer {{accessToken}}
}

script:post-response {
  test('Status 200', () => expect(res.getStatus()).to.equal(200));
  test('has memberId', () => expect(res.getBody()).to.have.property('memberId'));
}
