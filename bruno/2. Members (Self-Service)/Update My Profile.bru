meta {
  name: Update My Profile
  type: http
  seq: 2
  tags: [
    members
  ]
}

patch {
  url: {{baseUrl}}/members/me
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{accessToken}}
  Content-Type: application/json
}

body:json {
  {
    "name": "김영희",
    "phone": "01098765432"
  }
}

script:post-response {
  test('Status 200', () => expect(res.getStatus()).to.equal(200));
  test('name 반영', () => expect(res.getBody().name).to.eql('김영희'));
}
